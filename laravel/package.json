{
  "$schema": "https://www.schemastore.org/package.json",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyse": "vite build && open public/build/bundle-stats.html",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "lint": "eslint resources/js",
    "lint:fix": "eslint resources/js --fix",
    "type-check": "vue-tsc --noEmit",
    "prepare": "cd .. && husky laravel/.husky"
  },
  "lint-staged": {
    "resources/js/**/*.{ts,vue}": "eslint --fix",
    "../**/*.php": "../vendor/bin/pint"
  },
  "dependencies": {
    "@inertiajs/vue3": "^3.0.3",
    "@phosphor-icons/vue": "^2.2.1",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.6",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.0",
    "ziggy-js": "^2.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@pinia/testing": "^1.0.3",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.0",
    "concurrently": "^9.0.1",
    "cypress": "^15.14.0",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "laravel-vite-plugin": "^3.0.0",
    "lint-staged": "^16.4.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.0",
    "vitest": "^3.1.0",
    "vue-tsc": "^3.2.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "cypress",
      "esbuild",
      "rolldown",
      "vue-demi"
    ]
  }
}
